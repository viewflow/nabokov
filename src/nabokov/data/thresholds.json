{
  "readability_targets": {
    "ACCESSIBLE": {
      "tooFewWordCount": 8,
      "hardReadabilityLevel": 8,
      "veryHardReadabilityLevel": 12
    },
    "NORMAL": {
      "tooFewWordCount": 14,
      "hardReadabilityLevel": 10,
      "veryHardReadabilityLevel": 14
    },
    "TECHNICAL": {
      "tooFewWordCount": 14,
      "hardReadabilityLevel": 14,
      "veryHardReadabilityLevel": 18
    },
    "ESSAY": {
      "tooFewWordCount": 14,
      "hardReadabilityLevel": 14,
      "veryHardReadabilityLevel": 18
    }
  },
  "default_target": "NORMAL",
  "style_budgets": {
    "_note": "per-1000-word budgets for the style checks; within budget the findings are info, over it they are warnings. ESSAY is calibrated so the Paul Graham corpus stays advisory.",
    "ACCESSIBLE": {"NB301": 10, "NB302": 5, "NB303": 8, "NB401": 2},
    "NORMAL": {"NB301": 15, "NB302": 8, "NB303": 10, "NB401": 3},
    "TECHNICAL": {"NB301": 10, "NB302": 15, "NB303": 8, "NB401": 3},
    "ESSAY": {"NB301": 25, "NB302": 15, "NB303": 15, "NB401": 6}
  },
  "ari": {
    "coef_letters_per_word": 4.71,
    "coef_words_per_sentence": 0.5,
    "constant": 21.43,
    "note": "level=max(round(letters/words*4.71 + words/sentences*0.5 - 21.43),0); letters=count of \\w chars"
  },
  "passive_regex": "\\s(is|are|was|were|be|been|being)\\s([a-z]{2,30})\\b(\\sby\\b)?",
  "passive_participle_rule": "second word ends in 'ed' OR is a key in passive_irregulars",
  "adverb_rule": "token matches /ly$/ and lowercased token not in adverb_exceptions",
  "word_token_regex": "\\b[\\w'-]+\\b",
  "phrase_match_max_words": 4
}