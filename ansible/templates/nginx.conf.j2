# nabokov.viewflow.io — TLS edge. The app itself lives on jack.lan behind the
# persistent reverse SSH tunnel (127.0.0.1:9000 → jack:80, Caddy routes by Host).

# The lint API runs spaCy on arbitrary text — rate-limit it per IP at the edge.
limit_req_zone $binary_remote_addr zone=nabokov_api:1m rate=30r/m;

server {
  listen      80;
  listen   [::]:80;
  server_name {{ domain }};

  location /.well-known/acme-challenge {
    root {{ srv_dir }}/.letsencrypt;
  }

{% if cert_exists %}
  location / {
    return 301 https://$host$request_uri;
  }
}

server {
  listen      443 ssl http2;
  listen [::]:443 ssl http2;
  server_name {{ domain }};

  ssl_certificate         /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
  ssl_certificate_key     /etc/letsencrypt/live/{{ domain }}/privkey.pem;
  ssl_trusted_certificate /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
  ssl_session_cache shared:SSL:50m;
  ssl_session_timeout 1h;
  ssl_stapling on;
  ssl_stapling_verify on;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_prefer_server_ciphers on;
  ssl_dhparam /etc/nginx/dhparams.pem;

  access_log /var/log/nginx/{{ domain | replace('.', '-') }}.log;
  error_log /var/log/nginx/{{ domain | replace('.', '-') }}-error.log error;

  location /api/ {
    limit_req zone=nabokov_api burst=10 nodelay;
    client_max_body_size 64k;

    proxy_pass http://127.0.0.1:9000;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 60s;
    proxy_connect_timeout 10s;
  }

  location / {
    proxy_pass http://127.0.0.1:9000;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 30s;
    proxy_connect_timeout 10s;
  }
{% else %}
  # HTTP-only until the certificate exists; certbot needs the vhost live first.
  location / {
    return 503;
  }
{% endif %}
}
